page {
  background-color: #f3f4f7 !important;
}

.user-page {
  padding: 0 24rpx 40rpx;
}

.user-hero {
  margin-top: 24rpx;
  padding: 24rpx 28rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #fff7ef 0%, #ffffff 58%, #f8efe5 100%);
  box-shadow: 0 24rpx 60rpx rgba(162, 122, 81, 0.12);
}

.hero-toolbar {
  display: flex;
  justify-content: flex-end;
}

.toolbar-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3b2f27;
  font-size: 36rpx;
}

.hero-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 12rpx;
}

.hero-avatar {
  margin: auto;
}

.hero-name {
  margin-top: 24rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #221a14;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d6653;
}

.hero-member-tag {
  margin-top: 14rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-member-tag.is-member {
  background: rgba(199, 134, 63, 0.16);
  color: #9a5a19;
}

.hero-member-tag.is-guest {
  background: rgba(34, 26, 20, 0.08);
  color: #5a4d43;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.hero-button {
  min-width: 180rpx;
}

.hero-button.primary {
  background: #221a14;
  color: #fff;
}

.hero-button.warm {
  background: #c7863f;
  color: #fff;
}

.hero-button.secondary {
  background: #fff;
  color: #221a14;
  border: 1rpx solid rgba(34, 26, 20, 0.15);
}

.member-board,
.profile-board,
.quick-board,
.service-panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 50rpx rgba(17, 22, 33, 0.05);
}

.board-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.title-icon {
  margin-right: 12rpx;
  color: #c7863f;
  font-size: 34rpx;
}

.member-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.member-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff9f3 0%, #fff 100%);
  border: 1rpx solid rgba(199, 134, 63, 0.12);
}

.member-label,
.profile-label,
.quick-desc {
  font-size: 24rpx;
  color: #8d7765;
}

.member-value,
.profile-value,
.quick-label {
  color: #241b15;
  word-break: break-all;
}

.member-value {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.profile-list {
  margin-top: 20rpx;
}

.profile-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.profile-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.profile-value {
  max-width: 420rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: right;
}

.order-list {
  margin-top: 24rpx;
  border-radius: 40rpx;
  background-color: #ffffff;
}

.order-list-2 {
  background-image: linear-gradient(#fff, #f3f4f7);
}

.order-item {
  position: relative;
}

.order-link {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-badge {
  position: absolute;
  top: -6rpx;
  right: 18rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: #e34d59;
  color: #fff;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
  z-index: 2;
}

.order-image {
  width: 80rpx;
  height: 80rpx;
}

.quick-list {
  margin-top: 20rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.quick-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.quick-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff6ea 0%, #fff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #c7863f;
  font-size: 36rpx;
}

.quick-info {
  flex: 1;
  margin-left: 20rpx;
}

.quick-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.quick-label {
  font-size: 30rpx;
  font-weight: 600;
}

.quick-desc {
  margin-top: 8rpx;
}

.quick-arrow {
  color: #c0c4cc;
  margin-left: 16rpx;
}

.quick-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: #e34d59;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
}

.quick-extra {
  color: #8d7765;
  font-size: 22rpx;
}

.service-panel__desc {
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.8;
}

.service-panel__tips {
  margin-top: 18rpx;
}

.service-panel__tip {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 12rpx;
}

.service-panel__tip:first-child {
  margin-top: 0;
}

.service-panel__dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #c7863f;
  flex-shrink: 0;
}

.service-panel__text {
  color: #8d7765;
  font-size: 24rpx;
  line-height: 1.8;
}

.service-panel__button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #2967ff;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 88rpx;
}

.service-panel__button::after {
  border: none;
}

.head {
  box-shadow: 0 0 50rpx 10rpx rgba(211, 211, 211, 0.5);
}

.titles-color {
  color: rgb(107, 107, 107);
}

.text-black {
  color: #000 !important;
}

.order-all-link {
  color: #666;
}
