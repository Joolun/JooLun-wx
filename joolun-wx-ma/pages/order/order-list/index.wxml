<scroll-view scroll-x class="bg-white nav fixed">
  <view class="flex text-center">
    <view class="cu-item flex-sub {{index==tabCur?'text-blue cur':''}}" wx:for="{{orderStatus}}" wx:key="index" 
    bindtap="tabSelect" data-index="{{index}}" data-key="{{item.key}}">
      {{item.value}}
    </view>
  </view>
</scroll-view>
<view class="margin-top-bar">
  <view class="order-filter-board">
    <view class="order-filter-header">
      <view class="order-filter-title">售后快捷筛选</view>
      <view class="order-filter-link" bindtap="goAfterSaleCenter">进入售后中心</view>
    </view>
    <view class="order-filter-chip-list">
      <view
        class="order-filter-chip {{parameter.afterSaleStatus == item.key ? 'is-active' : ''}}"
        wx:for="{{afterSaleQuickFilters}}"
        wx:key="key"
        bindtap="afterSaleFilterSelect"
        data-key="{{item.key}}"
      >
        {{item.label}}
      </view>
    </view>
  </view>
  <view class="cu-card article">
    <view class="cu-item" wx:for="{{ orderList }}" wx:key="index" wx:for-index="index">
      <navigator hover-class='none' url='/pages/order/order-detail/index?id={{item.id}}'>
        <view class="cu-bar bg-white">
          <view class="action">
            <text class="cuIcon-titles text-black"></text> {{ item.createTime }}
          </view>
          <view class="action text-red">
            {{item.statusDesc}}
          </view>
        </view>
        <view class="order-after-sale-summary" wx:if="{{item.orderAfterSaleStatus}}">
          <view class="order-after-sale-tag {{item.orderAfterSaleStatus.type}}">{{item.orderAfterSaleStatus.label}}</view>
          <view class="order-after-sale-text">{{item.orderAfterSaleSummary}}</view>
        </view>
        <view class="cu-item padding-bottom" wx:for="{{ item.listOrderItem }}" wx:for-item="item2" wx:key="index" wx:for-index="index2">
          <view class="content">
            <image src="{{item2.picUrl ? item2.picUrl : '/public/img/no_pic.png'}}" mode="aspectFill" class="row-img margin-top-xs"></image>
            <view class="desc row-info margin-top-sm">
              <view class="text-black margin-top-sm overflow-2">{{item2.spuName}}</view>
              <view class="text-gray text-sm margin-top-sm overflow-2" wx:if="{{item2.specInfo}}">{{item2.specInfo}}</view>
              <view class="flex justify-between">
                <view class="text-price text-bold text-xl text-blue margin-top-sm">{{item2.paymentPrice}}</view>
                <view class="text-black text-sm margin-top-sm padding-lr-sm">x{{item2.quantity}}</view>
              </view>
            </view>
          </view>
          <view class="cu-item text-right padding-sm" catchtap wx:if="{{item2.afterSaleVisible}}">
            <view class="cu-btn line sm text-orange after-sale-status-btn">
              {{item2.afterSaleStatusText}}
            </view>
          </view>
        </view>
      </navigator>
      <order-operate
        class="response"
        orderInfo="{{item}}"
        bind:orderCancel="orderCancel"
        bind:orderReceive="orderCancel"
        bind:orderDel="orderDel"
        bind:unifiedOrder="unifiedOrder"
        data-index="{{index}}"/>
    </view>
  </view>
  <view class="order-empty-board" wx:if="{{orderList.length <= 0}}">
    <view class="order-empty-title">暂无订单</view>
    <view class="order-empty-desc">当前筛选条件下没有匹配订单，可以切换订单状态或售后筛选继续查看。</view>
  </view>
  <view class="cu-load bg-gray {{loadmore?'loading':'over'}}"></view>
</view>
