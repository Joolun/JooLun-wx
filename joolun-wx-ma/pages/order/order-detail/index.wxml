  - 多规格改造说明：
  - 1. 订单详情页通过 spuId + skuId 回跳商品详情。
  - 2. 历史订单展示以订单快照里的 specInfo 为准，不受商品后续改动影响。
-->
<view class="margin-bottom-bar">
  <view class="bg-white padding">
    <view class="status-desc text-red margin-left text-bold text-center cuIcon-{{orderInfo.status == '0' ? 'pay' : orderInfo.status == '1' ? 'send' : orderInfo.status == '2' ? 'deliver' : orderInfo.status == '3' ? 'evaluate' : orderInfo.status == '4' ? 'upstage' : orderInfo.status == '5' ? 'roundclose' : ''}}">
      {{orderInfo.statusDesc}}
    </view>
    <view class="text-black margin-left text-center" wx:if="{{orderInfo.isPay == '0' && !orderInfo.status}}">
      请在<count-down outTime="{{1000 * orderInfo.outTime}}" bind:countDownDone="countDownDone"/>内付款，超时订单将自动取消
    </view>
    <view class="text-black margin-left text-center" wx:if="{{orderInfo.status == '2'}}">
      还剩<count-down outTime="{{1000 * orderInfo.outTime}}" bind:countDownDone="countDownDone"/>自动确认
    </view>
  </view>
  <view class="cu-list cu-card menu-avatar">
    <navigator class="cu-item" url='/pages/order/order-logistics/index?id={{orderInfo.orderLogistics.id}}' wx:if="{{orderInfo.deliveryWay == '1' && (orderInfo.status == '2' || orderInfo.status == '3' || orderInfo.status == '4')}}">
      <view class="cu-avatar round cuIcon-deliver bg-red"></view>
      <view class="content loc-content">
        <view class="flex">
          <view class="text-black">{{orderInfo.orderLogistics.statusDesc}}</view>
          <view class="text-sm margin-left-sm">{{orderInfo.orderLogistics.logisticsDesc}}</view>
        </view>
        <view class="text-black text-sm overflow-2 loc-info" wx:if="{{orderInfo.orderLogistics.message}}">
					{{orderInfo.orderLogistics.message}}
        </view>
      </view>
      <view class="action">
        <text class="cuIcon-right"></text>
      </view>
    </navigator>
    <view class="cu-item">
      <view class="cu-avatar round cuIcon-location bg-black"></view>
      <view class="content loc-content">
        <view class="flex">
          <view class="text-black">{{orderInfo.orderLogistics.userName}}</view>
          <view class="text-gray text-sm margin-left-sm">{{orderInfo.orderLogistics.telNum}}</view>
        </view>
        <view class="text-gray text-sm overflow-2 loc-info">
					{{orderInfo.orderLogistics.address}}
        </view>
      </view>
    </view>
  </view>
  <view class="cu-card article mar-top-30">
    <view class="cu-item">
      <view class="cu-list menu">
        <!-- 订单商品列表直接渲染下单时冻结的 SKU 快照。 -->
        <view wx:for="{{ orderInfo.listOrderItem }}" wx:key="index">
          <navigator hover-class='none' url='/pages/goods/goods-detail/index?id={{item.spuId}}&skuId={{item.skuId}}' class="cu-item">
            <view class="align-center">
              <view class="flex align-center">
                <image src="{{item.picUrl ? item.picUrl : '/public/img/no_pic.png'}}" mode="aspectFill" class="row-img margin-top-xs"></image>
              </view>
                <view class="desc row-info">
                  <view class="text-black margin-left margin-top-sm overflow-2">{{item.spuName}}</view>
                  <view class="text-gray text-sm margin-top-sm overflow-2" wx:if="{{item.specInfo}}">{{item.specInfo}}</view>
                  <view class="flex justify-between">
                    <view class="text-bold text-gray margin-top-sm margin-left-xs padding-lr-sm font-weight">数量</view>
                    <view class="text-black text-sm margin-top-sm margin-right-xs padding-lr-sm">x{{item.quantity}}</view>
                  </view>
                  <view class="flex justify-between">
                    <view class="text-bold text-gray margin-top-sm margin-left-xs padding-lr-sm font-weight">是否退款</view>
                    <view class="text-black text-sm margin-top-sm margin-right-xs padding-lr-sm">{{item.isRefund == '0' ? '否' : '是'}}</view>
                  </view>
                  <view class="flex justify-between">
                    <view class="text-bold text-gray margin-top-sm margin-left-xs padding-lr-sm font-weight">状态</view>
                    <view class="text-black text-sm margin-top-sm margin-right-xs padding-lr-sm">{{item.afterSaleStatusText}}</view>
                  </view>
                  <view class="after-sale-panel" wx:if="{{item.afterSaleVisible}}">
                    <view class="after-sale-panel-header">
                      <view class="after-sale-panel-title">售后进度</view>
                      <view class="after-sale-panel-status">{{item.afterSaleStatusText}}</view>
                    </view>
                    <view class="after-sale-panel-line" wx:if="{{item.refundReason}}">
                      申请原因：{{item.refundReason}}
                    </view>
                    <view class="after-sale-panel-line" wx:if="{{item.refundAuditRemark}}">
                      审核备注：{{item.refundAuditRemark}}
                    </view>
                    <view class="after-sale-timeline" wx:if="{{item.afterSaleTimeline.length > 0}}">
                      <view class="after-sale-timeline-item" wx:for="{{item.afterSaleTimeline}}" wx:for-item="timelineItem" wx:key="title">
                        <view class="after-sale-timeline-dot"></view>
                        <view class="after-sale-timeline-content">
                          <view class="after-sale-timeline-title">{{timelineItem.title}}</view>
                          <view class="after-sale-timeline-time">{{timelineItem.time}}</view>
                          <view class="after-sale-timeline-desc">{{timelineItem.desc}}</view>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
            </view>
          </navigator>
          <view class="cu-item margin" wx:if="{{item.canApplyRefund}}" >
            <button
              class="cu-btn sm"
              bindtap="openRefundPopup"
              data-id="{{item.id}}"
              data-spu-name="{{item.spuName}}"
              data-spec-info="{{item.specInfo}}"
              data-payment-price="{{item.paymentPrice}}"
            >
              {{item.status == '2' ? '重新申请退款' : '申请退款'}}
            </button>
          </view>
        </view>
        <view class="cu-item margin-top-xs">
            <text class="text-gray font-weight">订单金额</text>
          <view class="action">
            <text class="text-price">{{orderInfo.salesPrice}}</text>
          </view>
        </view>
        <view class="cu-item margin-top-xs">
            <text class="text-gray font-weight">运费金额</text>
          <view class="action">
            + <text class="text-price">{{orderInfo.freightPrice}}</text>
          </view>
        </view>
        <view class="cu-item margin-top-xs">
            <text class="text-gray font-weight">支付金额</text>
          <view class="action">
            <text class="text-price text-xl text-blue text-bold">{{orderInfo.paymentPrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="cu-card mar-top-30">
    <view class="cu-item">
      <view class="cu-bar bg-white">
        <view class="action">
          <text class="cuIcon-titles text-black"></text>订单信息
        </view>
      </view>
      <view class="margin flex">
        <text class="flex-sub text-gray font-weight">订单编号</text>
        <view class="action">{{orderInfo.orderNo}}
          <button class="cu-btn sm" bindtap="copyData" data-data="{{orderInfo.orderNo}}">复制</button>
        </view>
      </view>
      <view class="margin flex">
        <text class="flex-sub text-gray font-weight">创建时间</text>
        <view class="action">{{orderInfo.createTime}}</view>
      </view>
      <view class="margin flex" wx:if="{{orderInfo.paymentTime}}">
        <text class="flex-sub text-gray font-weight">付款时间</text>
        <view class="action">{{orderInfo.paymentTime}}</view>
      </view>
    </view>
  </view>
  
  <view class="cu-card mar-top-30" wx:if="{{orderInfo.orderLogistics.logisticsDesc}}">
    <view class="cu-item">
      <view class="cu-bar bg-white">
        <view class="action">
          <text class="cuIcon-titles text-orange "></text> 物流信息
        </view>
      </view>
      <view class="margin flex">
        <text class="flex-sub">快递公司</text>
        <view class="flex-twice">
          {{orderInfo.orderLogistics.logisticsDesc}}
        </view>
      </view>
      <view class="margin flex">
        <text class="flex-sub">快递单号</text>
        <view class="flex-twice">
          {{orderInfo.orderLogistics.logisticsNo}}
          <button class="cu-btn sm" bindtap="copyData" data-data="{{orderInfo.orderLogistics.logisticsNo}}">复制</button>
        </view>
      </view>
    </view>
  </view>
  
  <view class="cu-card mar-top-30" wx:if="{{orderInfo.userMessage}}">
    <view class="cu-item cu-form-group align-start">
      <view class="title">给卖家留言</view>
      <textarea readonly value="{{orderInfo.userMessage}}"></textarea>
    </view>
	</view>
  <view class="service-board">
    <view class="service-board__title">订单服务支持</view>
    <view class="service-board__desc">发货、物流、退款审核等问题，建议优先带着当前订单发起咨询，客服处理会更快。</view>
    <button
      class="service-board__button"
      open-type="contact"
      bindcontact="handleContact"
      send-message-title="订单 {{orderInfo.orderNo}} 咨询"
      send-message-path="/pages/order/order-detail/index?id={{orderInfo.id}}"
      send-message-img="{{orderInfo.listOrderItem[0].picUrl ? orderInfo.listOrderItem[0].picUrl : '/public/img/no_pic.png'}}"
      show-message-card="true"
    >
      联系订单客服
    </button>
  </view>
  <view style="padding-bottom: 60px;">
	</view>
</view>
<view class="cu-bar tabbar bg-white border foot">
  <order-operate
    class="response"
    orderInfo="{{orderInfo}}"
    callPay="{{callPay}}"
    contact="true"
    bind:orderCancel="orderCancel"
    bind:orderReceive="orderCancel"
    bind:orderDel="orderDel"
    bind:unifiedOrder="unifiedOrder"
  />
</view>
<view wx:if="{{refundPopupVisible}}" class="refund-popup-mask" bindtap="closeRefundPopup"></view>
<view wx:if="{{refundPopupVisible}}" class="refund-popup-panel" catchtap="preventTouchMove">
  <view class="refund-popup-header">
    <view class="refund-popup-title">申请退款</view>
    <view class="refund-popup-close cuIcon-close" bindtap="closeRefundPopup"></view>
  </view>
  <view class="refund-popup-content">
    <view class="refund-goods-card">
      <view class="refund-goods-name">{{refundTarget.spuName || '未命名商品'}}</view>
      <view class="refund-goods-spec">{{refundTarget.specInfo || '默认规格'}}</view>
      <view class="refund-goods-price">退款金额：¥{{refundTarget.paymentPrice || '0.00'}}</view>
    </view>
    <view class="refund-form-label">退款原因</view>
    <textarea
      class="refund-textarea"
      maxlength="120"
      placeholder="请填写退款原因，方便商家更快审核"
      value="{{refundReason}}"
      bindinput="handleRefundReasonInput"
    ></textarea>
    <view class="refund-form-tip">请尽量描述清楚问题，例如商品有误、重复下单、暂不需要等。</view>
  </view>
  <view class="refund-popup-actions">
    <button class="cu-btn line-black round" bindtap="closeRefundPopup" disabled="{{refundSubmitting}}">取消</button>
    <button class="cu-btn bg-red round" bindtap="submitRefundApply" loading="{{refundSubmitting}}" disabled="{{refundSubmitting}}">
      提交申请
    </button>
  </view>
</view>
