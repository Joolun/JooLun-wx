.search-form {
  border-radius: 20rpx;
}

.screen-swiper {
  height: 480rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 96% !important;
  height: 350rpx !important;
  margin: 40rpx auto !important;
  border-radius: 20rpx;
  box-shadow: 0rpx 10rpx 60rpx rgba(211, 211, 211, 1);
}

.nav-section {
  margin-top: 8rpx;
}

.nav-image {
  width: 100rpx;
  height: 100rpx;
}

.adsec {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 7rpx 10rpx;
  height: 80rpx;
}

.swiper_container {
  height: 80rpx;
  width: 95%;
  line-height: 80rpx;
}

.text-black {
  color: #000 !important;
}

.home-service-card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: 0rpx 16rpx 48rpx rgba(41, 103, 255, 0.08);
}

.home-service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.home-service-title {
  font-size: 34rpx;
  font-weight: 700;
}

.home-service-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}

.home-service-btn {
  flex-shrink: 0;
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border: none;
  background: linear-gradient(135deg, #2967ff 0%, #4b8dff 100%);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 72rpx;
}

.home-service-btn::after {
  border: none;
}

.home-service-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.home-service-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f7ff;
  color: #2967ff;
  font-size: 22rpx;
  line-height: 1;
}

.home-service-shortcuts {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.home-service-shortcut {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 76rpx;
  border-radius: 20rpx;
  background: #f6f7fb;
  color: #1f2937;
  font-size: 24rpx;
  border: none;
}

.home-service-shortcut::after {
  border: none;
}

.home-service-shortcut.is-primary {
  background: #edf4ff;
  color: #2967ff;
  font-weight: 600;
}

.activity-section {
  padding: 0 24rpx;
}

.activity-item {
  margin-top: 24rpx;
}

.activity-image {
  width: 100%;
  height: 720rpx;
  border-radius: 24rpx;
}

.goods-group {
  margin-top: 20rpx;
}

.goods-group-header {
  align-items: flex-end;
}

.goods-group-sub-title {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.6;
}

.goods-group-more {
  color: #6b7280;
  font-size: 24rpx;
}

.home-service-float {
  position: fixed;
  right: 24rpx;
  bottom: 170rpx;
  z-index: 99;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  padding: 0;
  border-radius: 54rpx;
  background: linear-gradient(135deg, #2967ff 0%, #5ba0ff 100%);
  box-shadow: 0rpx 18rpx 36rpx rgba(41, 103, 255, 0.26);
  color: #ffffff;
  border: none;
}

.home-service-float::after {
  border: none;
}

.home-service-float-icon {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.home-service-float-text {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1;
}
